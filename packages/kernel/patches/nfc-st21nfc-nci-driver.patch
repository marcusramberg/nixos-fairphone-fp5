From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: NixOS-Fairphone-FP5 <noreply@example.com>
Date: Sun, 21 Jun 2026 00:00:00 +0000
Subject: [PATCH] NFC: add raw-NCI/I2C driver for ST21NFCD (Fairphone 5)

The Fairphone 5 NFC controller (ST21NFCD on I2C9) is a plain NCI 2.0
controller: 3-byte NCI header, IRQ-driven reads, no NDLC link layer and
no ST proprietary HCI/SET_NFC_MODE handshake. The existing st-nci driver
is therefore the wrong model -- it wraps every frame in NDLC and issues
proprietary commands the chip ignores, so the link never ACKs and
nci_request times out (endless NDLC retransmit storm observed on the
wire). The Fairphone Android kernel confirms this: its st21nfc driver is
a dumb char-device passthrough that lets userspace speak raw NCI.

Add a small driver that registers an nci_dev and transports raw NCI over
I2C, letting the kernel NCI core drive CORE_RESET/CORE_INIT and RF
discovery. Modelled on nxp-nci and st-nci. The reference clock (PMIC XO
buffer, there is no on-module crystal) is enabled for the lifetime of
the device. A proprietary power/field-monitor notification streamed by
the CLF is consumed silently.

Signed-off-by: NixOS-Fairphone-FP5 <noreply@example.com>
---
 drivers/nfc/Kconfig       |  11 ++
 drivers/nfc/Makefile      |   1 +
 drivers/nfc/st21nfc-nci.c | 291 +++++++++++
 3 files changed, 303 insertions(+)
 create mode 100644 drivers/nfc/st21nfc-nci.c

--- /dev/null
+++ b/drivers/nfc/st21nfc-nci.c
@@ -0,0 +1,291 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * Raw NCI over I2C driver for the STMicroelectronics ST21NFCD NFC controller
+ * as found on the Fairphone 5 (qcm6490).
+ *
+ * Unlike the st-nci driver, this controller speaks plain NCI over I2C: a
+ * 3-byte NCI header followed by the payload, IRQ-driven reads, no NDLC link
+ * layer and no ST proprietary HCI/SET_NFC_MODE handshake. The kernel NCI core
+ * therefore drives CORE_RESET/CORE_INIT and RF discovery directly.
+ *
+ * Modelled on drivers/nfc/nxp-nci and drivers/nfc/st-nci.
+ */
+
+#include <linux/clk.h>
+#include <linux/delay.h>
+#include <linux/gpio/consumer.h>
+#include <linux/i2c.h>
+#include <linux/interrupt.h>
+#include <linux/module.h>
+#include <linux/nfc.h>
+#include <linux/of.h>
+
+#include <net/nfc/nci.h>
+#include <net/nfc/nci_core.h>
+
+#define ST21NFC_NCI_DRIVER_NAME	"st21nfc_nci"
+
+#define ST21NFC_NCI_PROTOCOLS	(NFC_PROTO_JEWEL_MASK | \
+				 NFC_PROTO_MIFARE_MASK | \
+				 NFC_PROTO_FELICA_MASK | \
+				 NFC_PROTO_ISO14443_MASK | \
+				 NFC_PROTO_ISO14443_B_MASK | \
+				 NFC_PROTO_ISO15693_MASK | \
+				 NFC_PROTO_NFC_DEP_MASK)
+
+struct st21nfc_nci_phy {
+	struct i2c_client *i2c_dev;
+	struct nci_dev *ndev;
+
+	struct gpio_desc *gpiod_reset;
+	struct clk *clk;
+
+	bool powered;
+	int hard_fault; /* < 0 if a fatal I2C error occurred */
+};
+
+static int st21nfc_nci_open(struct nci_dev *ndev)
+{
+	struct st21nfc_nci_phy *phy = nci_get_drvdata(ndev);
+
+	if (phy->powered)
+		return 0;
+
+	phy->hard_fault = 0;
+
+	/* Reset pulse: drive the reset/VEN line low then high to (re)start
+	 * the CLF, then give it time to boot into NCI mode.
+	 */
+	gpiod_set_value_cansleep(phy->gpiod_reset, 0);
+	usleep_range(10000, 15000);
+	gpiod_set_value_cansleep(phy->gpiod_reset, 1);
+	usleep_range(80000, 85000);
+
+	enable_irq(phy->i2c_dev->irq);
+	phy->powered = true;
+
+	return 0;
+}
+
+static int st21nfc_nci_close(struct nci_dev *ndev)
+{
+	struct st21nfc_nci_phy *phy = nci_get_drvdata(ndev);
+
+	if (!phy->powered)
+		return 0;
+
+	disable_irq(phy->i2c_dev->irq);
+	gpiod_set_value_cansleep(phy->gpiod_reset, 0);
+	phy->powered = false;
+
+	return 0;
+}
+
+static int st21nfc_nci_send(struct nci_dev *ndev, struct sk_buff *skb)
+{
+	struct st21nfc_nci_phy *phy = nci_get_drvdata(ndev);
+	struct i2c_client *client = phy->i2c_dev;
+	int r;
+
+	if (phy->hard_fault != 0) {
+		kfree_skb(skb);
+		return phy->hard_fault;
+	}
+
+	r = i2c_master_send(client, skb->data, skb->len);
+	if (r < 0) {
+		/* Retry once, the chip may have been in standby. */
+		usleep_range(1000, 4000);
+		r = i2c_master_send(client, skb->data, skb->len);
+	}
+
+	if (r < 0) {
+		kfree_skb(skb);
+		return r;
+	}
+	if (r != skb->len) {
+		kfree_skb(skb);
+		return -EREMOTEIO;
+	}
+
+	consume_skb(skb);
+	return 0;
+}
+
+/*
+ * The CLF continuously emits a proprietary power/field-monitor notification
+ * (GID proprietary, OID 0x02). The NCI core has no use for it; consume it
+ * silently instead of logging "unsupported ntf opcode" for every frame.
+ */
+static int st21nfc_nci_prop_ntf(struct nci_dev *ndev, struct sk_buff *skb)
+{
+	return 0;
+}
+
+static const struct nci_driver_ops st21nfc_nci_prop_ops[] = {
+	{
+		.opcode = nci_opcode_pack(NCI_GID_PROPRIETARY, 0x02),
+		.ntf = st21nfc_nci_prop_ntf,
+	},
+};
+
+static const struct nci_ops st21nfc_nci_ops = {
+	.open = st21nfc_nci_open,
+	.close = st21nfc_nci_close,
+	.send = st21nfc_nci_send,
+	.prop_ops = st21nfc_nci_prop_ops,
+	.n_prop_ops = ARRAY_SIZE(st21nfc_nci_prop_ops),
+};
+
+/*
+ * Read one NCI frame: a 3-byte header (the third byte is the payload length)
+ * followed by that many payload bytes.
+ */
+static int st21nfc_nci_read(struct st21nfc_nci_phy *phy, struct sk_buff **skb)
+{
+	struct i2c_client *client = phy->i2c_dev;
+	struct nci_ctrl_hdr header;
+	int r;
+
+	r = i2c_master_recv(client, (u8 *)&header, NCI_CTRL_HDR_SIZE);
+	if (r < 0)
+		return r;
+	if (r != NCI_CTRL_HDR_SIZE)
+		return -EREMOTEIO;
+
+	*skb = alloc_skb(NCI_CTRL_HDR_SIZE + header.plen, GFP_KERNEL);
+	if (!*skb)
+		return -ENOMEM;
+
+	skb_put_data(*skb, &header, NCI_CTRL_HDR_SIZE);
+
+	if (!header.plen)
+		return 0;
+
+	r = i2c_master_recv(client, skb_put(*skb, header.plen), header.plen);
+	if (r != header.plen) {
+		kfree_skb(*skb);
+		*skb = NULL;
+		return r < 0 ? r : -EREMOTEIO;
+	}
+
+	return 0;
+}
+
+static irqreturn_t st21nfc_nci_irq_thread_fn(int irq, void *phy_id)
+{
+	struct st21nfc_nci_phy *phy = phy_id;
+	struct sk_buff *skb = NULL;
+	int r;
+
+	if (!phy || !phy->ndev || irq != phy->i2c_dev->irq) {
+		WARN_ON_ONCE(1);
+		return IRQ_NONE;
+	}
+
+	if (phy->hard_fault != 0)
+		return IRQ_HANDLED;
+
+	r = st21nfc_nci_read(phy, &skb);
+	if (r == -EREMOTEIO)
+		phy->hard_fault = r;
+	if (r < 0)
+		return IRQ_HANDLED;
+
+	nci_recv_frame(phy->ndev, skb);
+
+	return IRQ_HANDLED;
+}
+
+static int st21nfc_nci_probe(struct i2c_client *client)
+{
+	struct device *dev = &client->dev;
+	struct st21nfc_nci_phy *phy;
+	int r;
+
+	if (!i2c_check_functionality(client->adapter, I2C_FUNC_I2C)) {
+		nfc_err(dev, "Need I2C_FUNC_I2C\n");
+		return -ENODEV;
+	}
+
+	phy = devm_kzalloc(dev, sizeof(*phy), GFP_KERNEL);
+	if (!phy)
+		return -ENOMEM;
+
+	phy->i2c_dev = client;
+	i2c_set_clientdata(client, phy);
+
+	/* Keep the CLF in reset until the NCI core opens the device. */
+	phy->gpiod_reset = devm_gpiod_get(dev, "reset", GPIOD_OUT_LOW);
+	if (IS_ERR(phy->gpiod_reset))
+		return dev_err_probe(dev, PTR_ERR(phy->gpiod_reset),
+				     "Unable to get reset GPIO\n");
+
+	/* Reference clock from the PMIC XO buffer (no on-module crystal). */
+	phy->clk = devm_clk_get_optional_enabled(dev, "nfc_ref_clk");
+	if (IS_ERR(phy->clk))
+		return dev_err_probe(dev, PTR_ERR(phy->clk),
+				     "Unable to get/enable reference clock\n");
+
+	phy->ndev = nci_allocate_device(&st21nfc_nci_ops, ST21NFC_NCI_PROTOCOLS,
+					0, 0);
+	if (!phy->ndev)
+		return -ENOMEM;
+
+	nci_set_parent_dev(phy->ndev, dev);
+	nci_set_drvdata(phy->ndev, phy);
+
+	r = nci_register_device(phy->ndev);
+	if (r) {
+		nci_free_device(phy->ndev);
+		return r;
+	}
+
+	/* IRQ stays disabled until the NCI core opens the device. */
+	r = devm_request_threaded_irq(dev, client->irq, NULL,
+				      st21nfc_nci_irq_thread_fn,
+				      IRQF_ONESHOT | IRQF_NO_AUTOEN,
+				      ST21NFC_NCI_DRIVER_NAME, phy);
+	if (r < 0) {
+		nfc_err(dev, "Unable to register IRQ handler\n");
+		nci_unregister_device(phy->ndev);
+		nci_free_device(phy->ndev);
+		return r;
+	}
+
+	return 0;
+}
+
+static void st21nfc_nci_remove(struct i2c_client *client)
+{
+	struct st21nfc_nci_phy *phy = i2c_get_clientdata(client);
+
+	nci_unregister_device(phy->ndev);
+	nci_free_device(phy->ndev);
+}
+
+static const struct i2c_device_id st21nfc_nci_id_table[] = {
+	{ ST21NFC_NCI_DRIVER_NAME },
+	{}
+};
+MODULE_DEVICE_TABLE(i2c, st21nfc_nci_id_table);
+
+static const struct of_device_id of_st21nfc_nci_match[] = {
+	{ .compatible = "st,st21nfcd-i2c", },
+	{}
+};
+MODULE_DEVICE_TABLE(of, of_st21nfc_nci_match);
+
+static struct i2c_driver st21nfc_nci_driver = {
+	.driver = {
+		.name = ST21NFC_NCI_DRIVER_NAME,
+		.of_match_table = of_st21nfc_nci_match,
+	},
+	.probe = st21nfc_nci_probe,
+	.id_table = st21nfc_nci_id_table,
+	.remove = st21nfc_nci_remove,
+};
+module_i2c_driver(st21nfc_nci_driver);
+
+MODULE_LICENSE("GPL");
+MODULE_DESCRIPTION("Raw NCI/I2C driver for ST21NFCD (Fairphone 5)");
--- a/drivers/nfc/Makefile
+++ b/drivers/nfc/Makefile
@@ -14,6 +14,7 @@
 obj-$(CONFIG_NFC_TRF7970A)	+= trf7970a.o
 obj-$(CONFIG_NFC_ST21NFCA)  	+= st21nfca/
 obj-$(CONFIG_NFC_ST_NCI)	+= st-nci/
+obj-$(CONFIG_NFC_ST21NFC_NCI)	+= st21nfc-nci.o
 obj-$(CONFIG_NFC_NXP_NCI)	+= nxp-nci/
 obj-$(CONFIG_NFC_S3FWRN5)	+= s3fwrn5/
 obj-$(CONFIG_NFC_ST95HF)	+= st95hf/
--- a/drivers/nfc/Kconfig
+++ b/drivers/nfc/Kconfig
@@ -60,6 +60,17 @@
 
 	  If unsure, say N.
 
+config NFC_ST21NFC_NCI
+	tristate "STMicroelectronics ST21NFCD NCI/I2C support"
+	depends on NFC_NCI && I2C
+	help
+	  This adds support for the STMicroelectronics ST21NFCD NFC controller
+	  as used on the Fairphone 5, driven as a plain NCI controller over
+	  I2C (no NDLC link layer).
+
+	  To compile this driver as a module, choose m here. The module will
+	  be called st21nfc-nci.
+
 source "drivers/nfc/fdp/Kconfig"
 source "drivers/nfc/pn544/Kconfig"
 source "drivers/nfc/pn533/Kconfig"
